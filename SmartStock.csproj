<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <Folder Include="Classes\Models\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FontAwesome.Sharp" Version="6.3.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Forms\LoginForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Forms\User Control\MailConfirmation.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\User Control\Settings.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\User Control\AddAccount.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\User Control\AddExternalFactor.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\User Control\AddSale.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\User Control\AddCustomer.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\User Control\AddTransaction.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\User Control\AddSupplier.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\User Control\BaseAddProduct.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Properties\Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Properties\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

</Project>