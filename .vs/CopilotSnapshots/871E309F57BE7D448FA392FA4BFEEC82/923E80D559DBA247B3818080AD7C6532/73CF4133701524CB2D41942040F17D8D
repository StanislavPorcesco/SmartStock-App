    public partial class AddAccount : UserControl
    {
        public AddAccount()
        {
            InitializeComponent();

            // Fix the control ordering issue: panel1 (with buttons) should be visible at the bottom
            // It was being hidden by selector_pnl which is docked to Top
            // Solution: Bring panel1 to front so it appears above other controls
            if (base_pnl != null && base_pnl.Controls.Contains(options_pnl))
            {
                options_pnl.BringToFront();
            }

            ThemeManager.Apply(this);

            // Force layout calculation to ensure all controls are visible
            this.SuspendLayout();
            this.PerformLayout();
            this.ResumeLayout(true);
            this.Invalidate(true);
            this.Update();
            this.Refresh();

            // Subscribe to theme changes
            ThemeManager.OnThemeChanged += HandleThemeUpdate;
        }

        private void HandleThemeUpdate()
        {
            ThemeManager.Apply(this);
            this.Refresh();
        }

