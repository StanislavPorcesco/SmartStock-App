using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace SmartStock.Forms
{
    public partial class MenuForm : Form
    {
        public MenuForm()
        {
            InitializeComponent();

            // Enable double buffering on the main form to prevent flicker
            this.DoubleBuffered = true;

            // Enable double buffering on the menu panel to prevent IconButton rendering artifacts
            SetDoubleBuffered(menu_pnl, true);

            // Prevent form from showing until layout is fully calculated
            this.Visible = false;
        }

        protected override void OnLoad(EventArgs e)
        {
            base.OnLoad(e);

            // Force complete layout calculation before form becomes visible
            // This ensures all docking calculations are finalized
            this.SuspendLayout();

            // Recalculate all child control layouts
            this.PerformLayout();

            // Force synchronous layout of the entire control tree
            this.Refresh();

            this.ResumeLayout(false);

            // Invoke on the UI thread to ensure all layouts are finalized
            // before the form is shown to the user
            this.BeginInvoke(new Action(() =>
            {
                this.Visible = true;

                // Force recalculation of hit test regions for all IconButtons
                // This is critical because FontAwesome.Sharp IconButton caches hit test regions
                InvalidateChildHitTests(this);
            }));
        }

        protected override void OnLayout(LayoutEventArgs levent)
        {
            base.OnLayout(levent);

            // After any layout change, invalidate hit test regions for custom controls
            // This ensures mouse tracking works correctly with the updated bounds
            InvalidateChildHitTests(this);
        }

        protected override void OnMouseMove(MouseEventArgs e)
        {
            base.OnMouseMove(e);

            // Periodically refresh hit test regions during mouse movement
            // This works around FontAwesome.Sharp's cached hit test region issue
            if (e.Button == MouseButtons.None)
            {
                InvalidateChildHitTests(menu_pnl);
            }
        }

        /// <summary>
        /// Recursively invalidates the hit test region for all child controls.
        /// FontAwesome.Sharp IconButton caches hit test regions, which can become stale
        /// after layout changes. This method forces recalculation.
        /// </summary>
        private void InvalidateChildHitTests(Control parent)
        {
            foreach (Control child in parent.Controls)
            {
                // Force the control to recalculate its hit test region
                child.Invalidate();

                // For custom controls like FontAwesome.Sharp IconButton, we need to
                // also reset the window region to force WinForms to recalculate
                if (child.IsHandleCreated && child is Button)
                {
                    // Call Invalidate on the child's region to force hit test recalculation
                    try
                    {
                        // Use native Windows API to refresh the region
                        NativeInterop.InvalidateRect(child.Handle, IntPtr.Zero, true);
                    }
                    catch
                    {
                        // Silently fail if native call is not available
                    }
                }

                // Recursively process child controls
                if (child.HasChildren)
                {
                    InvalidateChildHitTests(child);
                }
            }
        }

        /// <summary>
        /// Helper method to enable DoubleBuffered on controls via reflection since it's protected.
        /// This reduces rendering flicker and visual artifacts during layout changes.
        /// </summary>
        private static void SetDoubleBuffered(Control control, bool enabled)
        {
            var property = control.GetType().GetProperty("DoubleBuffered",
                System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);
            if (property != null && property.CanWrite)
            {
                property.SetValue(control, enabled, null);
            }
        }
    }

    /// <summary>
    /// Native interop for Windows API calls needed to fix hit test region issues.
    /// </summary>
    public static class NativeInterop
    {
        [System.Runtime.InteropServices.DllImport("user32.dll", SetLastError = true)]
        public static extern bool InvalidateRect(IntPtr hWnd, IntPtr lpRect, bool bErase);
    }
}
