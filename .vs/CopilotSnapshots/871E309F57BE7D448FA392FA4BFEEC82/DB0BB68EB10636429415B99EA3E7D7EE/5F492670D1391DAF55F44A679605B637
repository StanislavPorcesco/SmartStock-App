using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace SmartStock.Forms
{
    public partial class MenuForm : Form
    {
        public MenuForm()
        {
            InitializeComponent();

            // Enable double buffering on the main form to prevent flicker
            this.DoubleBuffered = true;

            // Enable double buffering on the menu panel to prevent IconButton rendering artifacts
            menu_pnl.DoubleBuffered = true;

            // Prevent form from showing until layout is fully calculated
            this.Visible = false;
        }

        protected override void OnLoad(EventArgs e)
        {
            base.OnLoad(e);

            // Force complete layout calculation before form becomes visible
            // This ensures all docking calculations are finalized
            this.SuspendLayout();

            // Recalculate all child control layouts
            this.PerformLayout();

            // Force synchronous layout of the entire control tree
            this.Refresh();

            this.ResumeLayout(false);

            // Invoke on the UI thread to ensure all layouts are finalized
            // before the form is shown to the user
            this.BeginInvoke(new Action(() =>
            {
                this.Visible = true;
            }));
        }
    }
}
