using System.ComponentModel.DataAnnotations;
using System.ComponentModel.DataAnnotations.Schema;

namespace SmartStock.Classes.Models
{
    /// <summary>
    /// Entitatea de domeniu ExternalFactor - curată de orice logică de bază de date.
    /// Conține factori externi (Economic, Social, Weather) care influențează vânzările.
    /// Logica de acces la date și calculele este delegată ExternalFactorService.
    /// </summary>
    public class ExternalFactor
    {
        [Key]
        public int FactorId { get; set; }

        [Required]
        [StringLength(50)]
        public string FactorType { get; set; } // Economic, Social, Weather, etc.

        [StringLength(250)]
        public string Description { get; set; }

        // NOU: Sursa informației (ex: link către știre sau numele API-ului)
        [StringLength(100)]
        public string Source { get; set; }

        [StringLength(100)]
        public string Region { get; set; }

        [Required]
        [Column(TypeName = "decimal(18, 4)")]
        public decimal ImpactValue { get; set; }

        [Required]
        [StringLength(20)]
        public string ValueType { get; set; } // Absolute, Percentage, Multiplier

        // NOU: Permite filtrare rapidă fără calcule matematice complexe
        [StringLength(20)]
        public string Severity { get; set; } // Low, Medium, High, Critical

        [Required]
        public DateTime Date { get; set; } = DateTime.Now;

        [Required]
        public bool IsActive { get; set; } = true;

        // NOU: Pentru grupări de evenimente (ex: "Pandemic", "Holiday", "Crisis")
        [StringLength(100)]
        public string Tags { get; set; }
    }
}
