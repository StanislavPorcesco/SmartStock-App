using SmartStock.Classes.Data.Interfaces;
using SmartStock.Classes.Models;

namespace SmartStock.Classes.Data.Services
{
    /// <summary>
    /// Serviciu pentru logica de business a modelelor econometrice.
    /// Gestionează analiza modelelor statistice, calculul corelațiilor și evaluarea semnificației.
    /// </summary>
    public class EconometricService
    {
        private readonly IRepository<EconometricModel> _modelRepository;
        private readonly IEconometricEngine _econometricEngine;

        public EconometricService(IRepository<EconometricModel> modelRepository, IEconometricEngine econometricEngine)
        {
            _modelRepository = modelRepository ?? throw new ArgumentNullException(nameof(modelRepository));
            _econometricEngine = econometricEngine ?? throw new ArgumentNullException(nameof(econometricEngine));
        }

        /// <summary>
        /// Verifică dacă un model economic este semnificativ din punct de vedere statistic.
        /// Un model este semnificativ dacă p-value < 0.05
        /// </summary>
        /// <param name="modelId">ID-ul modelului de verificat</param>
        /// <returns>True dacă modelul este semnificativ statistic</returns>
        public async Task<bool> IsModelStatisticallySignificantAsync(int modelId)
        {
            var model = await _modelRepository.GetByIdAsync(modelId);
            if (model == null)
                return false;

            // Dacă p-value este mic, factorul are impact real, nu e întâmplător
            return model.PValue < 0.05m;
        }

        /// <summary>
        /// Actualizează parametrii unui model econometric cu noile valori calculate.
        /// </summary>
        /// <param name="modelId">ID-ul modelului de actualizat</param>
        /// <param name="coefficientValue">Noua valoare a coeficientului</param>
        /// <param name="pValue">Noua valoare p (semnificație statistică)</param>
        /// <param name="rSquared">Noua valoare R-squared (precizie)</param>
        public async Task UpdateModelParametersAsync(int modelId, decimal coefficientValue, decimal pValue, decimal rSquared)
        {
            if (coefficientValue < 0)
                throw new ArgumentException("Coefficient value cannot be negative", nameof(coefficientValue));

            if (pValue < 0 || pValue > 1)
                throw new ArgumentException("P-value must be between 0 and 1", nameof(pValue));

            if (rSquared < 0 || rSquared > 1)
                throw new ArgumentException("R-squared must be between 0 and 1", nameof(rSquared));

            var model = await _modelRepository.GetByIdAsync(modelId);
            if (model == null)
                throw new InvalidOperationException($"Model with ID {modelId} not found");

            model.CoefficientValue = coefficientValue;
            model.PValue = pValue;
            model.RSquared = rSquared;
            model.LastTrainedDate = DateTime.Now;

            _modelRepository.Update(model);
            await _modelRepository.SaveAsync();
        }

        /// <summary>
        /// Obține modelul cu cea mai bună performanță (cel mai mare R-squared).
        /// </summary>
        /// <returns>Modelul cel mai bun performant sau null dacă nu există modele</returns>
        public async Task<EconometricModel> GetBestPerformingModelAsync()
        {
            var allModels = _modelRepository.GetAll();
            return allModels
                .OrderByDescending(m => m.RSquared)
                .FirstOrDefault();
        }

        /// <summary>
        /// Adaugă un nou model econometric.
        /// </summary>
        /// <param name="model">Modelul de adăugat</param>
        public async Task AddModelAsync(EconometricModel model)
        {
            if (model == null)
                throw new ArgumentNullException(nameof(model));

            _modelRepository.Add(model);
            await _modelRepository.SaveAsync();
        }

        /// <summary>
        /// Obține toți modelii care sunt semnificativi statistic.
        /// </summary>
        /// <returns>Lista modelilor semnificativi</returns>
        public async Task<List<EconometricModel>> GetSignificantModelsAsync()
        {
            var allModels = _modelRepository.GetAll();
            var significantModels = new List<EconometricModel>();

            foreach (var model in allModels)
            {
                if (model.PValue < 0.05m)
                {
                    significantModels.Add(model);
                }
            }

            return significantModels;
        }

        /// <summary>
        /// Obține modelii sorțați după performanță (R-squared descrescător).
        /// </summary>
        /// <param name="topCount">Numărul de top modele de returnat (null pentru toți)</param>
        /// <returns>Lista modelilor sortați după performanță</returns>
        public async Task<List<EconometricModel>> GetModelsByPerformanceAsync(int? topCount = null)
        {
            var allModels = _modelRepository.GetAll()
                .OrderByDescending(m => m.RSquared)
                .ToList();

            if (topCount.HasValue && topCount.Value > 0)
            {
                allModels = allModels.Take(topCount.Value).ToList();
            }

            return allModels;
        }

        /// <summary>
        /// Obține tendințele analize pentru un produs specific.
        /// </summary>
        /// <param name="productId">ID-ul produsului</param>
        /// <returns>Modelul econometric cu analiza tendințelor</returns>
        public async Task<EconometricModel> GetTrendAnalysisAsync(int productId)
        {
            return await _econometricEngine.GetTrendAnalysisAsync(productId);
        }

        /// <summary>
        /// Șterge un model din baza de date.
        /// </summary>
        /// <param name="modelId">ID-ul modelului de șters</param>
        public async Task DeleteModelAsync(int modelId)
        {
            var model = await _modelRepository.GetByIdAsync(modelId);
            if (model != null)
            {
                _modelRepository.Delete(model);
                await _modelRepository.SaveAsync();
            }
        }
    }
}
