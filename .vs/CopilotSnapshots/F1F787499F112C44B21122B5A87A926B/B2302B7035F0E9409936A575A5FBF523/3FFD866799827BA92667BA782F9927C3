using Microsoft.EntityFrameworkCore;
using SmartStock.Classes.Data.Interfaces;
using SmartStock.Classes.Models;

namespace SmartStock.Classes.Data.Services
{
    /// <summary>
    /// Serviciu pentru logica de business a recomandărilor de stoc.
    /// Gestionează crearea, preluarea și filtrarea recomandărilor AI pentru inventar.
    /// </summary>
    public class RecommendationService
    {
        private readonly IRepository<AiStockRecommendation> _recommendationRepository;

        public RecommendationService(IRepository<AiStockRecommendation> recommendationRepository)
        {
            _recommendationRepository = recommendationRepository ?? throw new ArgumentNullException(nameof(recommendationRepository));
        }

        /// <summary>
        /// Adaugă o nouă recomandare de stoc.
        /// </summary>
        /// <param name="recommendation">Recomandarea de adăugat</param>
        public async Task AddRecommendationAsync(AiStockRecommendation recommendation)
        {
            if (recommendation == null)
                throw new ArgumentNullException(nameof(recommendation));

            _recommendationRepository.Add(recommendation);
            await _recommendationRepository.SaveAsync();
        }

        /// <summary>
        /// Adaugă mai multe recomandări în batch.
        /// </summary>
        /// <param name="recommendations">Colecția de recomandări de adăugat</param>
        public async Task AddRecommendationsAsync(IEnumerable<AiStockRecommendation> recommendations)
        {
            if (recommendations == null)
                throw new ArgumentNullException(nameof(recommendations));

            _recommendationRepository.AddRange(recommendations);
            await _recommendationRepository.SaveAsync();
        }

        /// <summary>
        /// Obține toți recomandările urgente (cu prioritate ridicată).
        /// </summary>
        /// <returns>Lista recomandărilor urgente sortate descrescător după dată creării</returns>
        public async Task<List<AiStockRecommendation>> GetUrgentRecommendationsAsync()
        {
            var recommendations = await _recommendationRepository
                .FindAsync(r => r.PriorityLevel == "High");

            return recommendations
                .OrderByDescending(r => r.CreatedAt)
                .ToList();
        }

        /// <summary>
        /// Obține recomandările după nivelul de prioritate.
        /// </summary>
        /// <param name="priorityLevel">Nivelul de prioritate ("Low", "Medium", "High")</param>
        /// <returns>Lista recomandărilor cu prioritatea specificată</returns>
        public async Task<List<AiStockRecommendation>> GetRecommendationsByPriorityAsync(string priorityLevel)
        {
            if (string.IsNullOrWhiteSpace(priorityLevel))
                throw new ArgumentException("Priority level cannot be null or empty", nameof(priorityLevel));

            var recommendations = await _recommendationRepository
                .FindAsync(r => r.PriorityLevel == priorityLevel);

            return recommendations
                .OrderByDescending(r => r.CreatedAt)
                .ToList();
        }

        /// <summary>
        /// Obține recomandări pentru un anumit produs.
        /// </summary>
        /// <param name="productId">ID-ul produsului</param>
        /// <returns>Lista recomandărilor pentru produs</returns>
        public async Task<List<AiStockRecommendation>> GetRecommendationsByProductAsync(int productId)
        {
            var recommendations = await _recommendationRepository
                .FindAsync(r => r.ProductId == productId);

            return recommendations
                .OrderByDescending(r => r.CreatedAt)
                .ToList();
        }

        /// <summary>
        /// Șterge recomandări vechi (mai vechi de N zile).
        /// </summary>
        /// <param name="daysOld">Numărul de zile pentru a considera o recomandare ca fiind veche (implicit 7)</param>
        public async Task RemoveObsoleteRecommendationsAsync(int daysOld = 7)
        {
            if (daysOld < 0)
                throw new ArgumentException("Days old must be non-negative", nameof(daysOld));

            var cutoffDate = DateTime.Now.AddDays(-daysOld);
            var oldRecommendations = await _recommendationRepository
                .FindAsync(r => r.CreatedAt < cutoffDate);

            if (oldRecommendations.Count > 0)
            {
                _recommendationRepository.DeleteRange(oldRecommendations);
                await _recommendationRepository.SaveAsync();
            }
        }

        /// <summary>
        /// Obține recomandări recente (din ultimele N zile).
        /// </summary>
        /// <param name="daysBack">Numărul de zile în trecut</param>
        /// <returns>Lista recomandărilor recente</returns>
        public async Task<List<AiStockRecommendation>> GetRecentRecommendationsAsync(int daysBack = 7)
        {
            if (daysBack < 0)
                throw new ArgumentException("Days back must be non-negative", nameof(daysBack));

            var cutoffDate = DateTime.Now.AddDays(-daysBack);
            var recommendations = await _recommendationRepository
                .FindAsync(r => r.CreatedAt >= cutoffDate);

            return recommendations
                .OrderByDescending(r => r.CreatedAt)
                .ToList();
        }

        /// <summary>
        /// Obține recomandările cu cea mai mare cantitate sugerată.
        /// </summary>
        /// <param name="count">Numărul de recomandări de returnat</param>
        /// <returns>Lista cu cele mai mari recomandări de cantitate</returns>
        public async Task<List<AiStockRecommendation>> GetTopQuantityRecommendationsAsync(int count = 10)
        {
            if (count <= 0)
                throw new ArgumentException("Count must be positive", nameof(count));

            var allRecommendations = _recommendationRepository.GetAll();
            return await allRecommendations
                .OrderByDescending(r => r.SuggestedQuantity)
                .Take(count)
                .AsNoTracking()
                .ToListAsync();
        }
    }
}
