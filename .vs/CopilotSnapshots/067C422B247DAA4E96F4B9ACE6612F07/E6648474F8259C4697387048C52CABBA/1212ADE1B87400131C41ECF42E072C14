using Microsoft.EntityFrameworkCore;
using SmartStock.Classes.Data.DTOs;
using SmartStock.Classes.Data.Interfaces;
using SmartStock.Classes.Models;

namespace SmartStock.Classes.Data.Services
{
    /// <summary>
    /// Serviciu pentru logica de business a entității Sale.
    /// Conține toate query-urile LINQ, calculele, logica de filtrare și procesarea tranzacțiilor.
    /// Gestionează relațiile cu SaleDetails, Product Stock, și Transaction history.
    /// </summary>
    public class SaleService
    {
        private readonly IRepository<Sale> _saleRepository;
        private readonly IRepository<SaleDetails> _saleDetailsRepository;
        private readonly IRepository<Product> _productRepository;
        private readonly IRepository<Transaction> _transactionRepository;

        public SaleService(
            IRepository<Sale> saleRepository,
            IRepository<SaleDetails> saleDetailsRepository = null,
            IRepository<Product> productRepository = null,
            IRepository<Transaction> transactionRepository = null)
        {
            _saleRepository = saleRepository ?? throw new ArgumentNullException(nameof(saleRepository));
            _saleDetailsRepository = saleDetailsRepository;
            _productRepository = productRepository;
            _transactionRepository = transactionRepository;
        }

        /// <summary>
        /// Obține toate vânzările active.
        /// </summary>
        public async Task<List<Sale>> GetAllActiveAsync()
        {
            return await _saleRepository
                .GetAll()
                .Where(s => s.IsActive)
                .OrderByDescending(s => s.SaleDate)
                .AsNoTracking()
                .ToListAsync();
        }

        /// <summary>
        /// Obține o vânzare cu detaliile, clientul și utilizatorul.
        /// </summary>
        public async Task<Sale> GetWithDetailsAsync(int saleId)
        {
            return await _saleRepository
                .GetAll()
                .Where(s => s.SaleId == saleId)
                .Include(s => s.SaleDetails)
                .Include(s => s.Customer)
                .Include(s => s.User)
                .AsNoTracking()
                .FirstOrDefaultAsync();
        }

        /// <summary>
        /// Filtrează vânzările conform criteriilor furnizate.
        /// </summary>
        public async Task<List<Sale>> GetFilteredAsync(SaleFilterCriteria criteria)
        {
            if (criteria == null)
                throw new ArgumentNullException(nameof(criteria));

            IQueryable<Sale> query = _saleRepository.GetAll();

            // Filtru după stare
            if (criteria.IsActive.HasValue)
            {
                query = query.Where(s => s.IsActive == criteria.IsActive.Value);
            }
            else
            {
                query = query.Where(s => s.IsActive);
            }

            // Filtru după client
            if (criteria.CustomerId.HasValue)
            {
                query = query.Where(s => s.CustomerId == criteria.CustomerId.Value);
            }

            // Filtru după utilizator
            if (criteria.UserId.HasValue)
            {
                query = query.Where(s => s.UserId == criteria.UserId.Value);
            }

            // Filtru după status de plată
            if (!string.IsNullOrWhiteSpace(criteria.PaymentStatus))
            {
                var statusLower = criteria.PaymentStatus.ToLower();
                query = query.Where(s => s.PaymentStatus.ToLower() == statusLower);
            }

            // Filtru după metoda de plată
            if (!string.IsNullOrWhiteSpace(criteria.PaymentMethod))
            {
                var methodLower = criteria.PaymentMethod.ToLower();
                query = query.Where(s => s.PaymentMethod.ToLower() == methodLower);
            }

            // Filtru după dată de vânzare (de la)
            if (criteria.SaleDateFrom.HasValue)
            {
                query = query.Where(s => s.SaleDate >= criteria.SaleDateFrom.Value);
            }

            // Filtru după dată de vânzare (până la)
            if (criteria.SaleDateTo.HasValue)
            {
                var endDate = criteria.SaleDateTo.Value.AddDays(1); // Include the entire day
                query = query.Where(s => s.SaleDate < endDate);
            }

            // Filtru după suma minimă
            if (criteria.TotalAmountMin.HasValue)
            {
                query = query.Where(s => s.TotalAmount >= criteria.TotalAmountMin.Value);
            }

            // Filtru după suma maximă
            if (criteria.TotalAmountMax.HasValue)
            {
                query = query.Where(s => s.TotalAmount <= criteria.TotalAmountMax.Value);
            }

            // Sortare
            query = ApplySorting(query, criteria.SortBy, criteria.SortOrder);

            // Paginare
            if (criteria.PageSize > 0)
            {
                query = query.Skip((criteria.PageNumber - 1) * criteria.PageSize)
                             .Take(criteria.PageSize);
            }

            return await query.AsNoTracking().ToListAsync();
        }

        /// <summary>
        /// Obține detaliile unei vânzări.
        /// </summary>
        public async Task<List<SaleDetails>> GetSaleDetailsAsync(int saleId)
        {
            if (_saleDetailsRepository == null)
                throw new InvalidOperationException("SaleDetailsRepository not provided");

            return await _saleDetailsRepository
                .GetAll()
                .Where(d => d.SaleId == saleId)
                .AsNoTracking()
                .ToListAsync();
        }

        /// <summary>
        /// Obține statistici de vânzări (revenue, count, average).
        /// </summary>
        public async Task<dynamic> GetSalesStatsAsync(DateTime fromDate, DateTime toDate)
        {
            var stats = await _saleRepository
                .GetAll()
                .Where(s => s.IsActive && s.SaleDate >= fromDate && s.SaleDate < toDate.AddDays(1))
                .GroupBy(s => 1)
                .Select(g => new
                {
                    TotalSales = g.Count(),
                    TotalRevenue = g.Sum(s => (double?)s.TotalAmount) ?? 0.0,
                    AverageOrderValue = g.Count() > 0 ? g.Average(s => (double?)s.TotalAmount) ?? 0.0 : 0.0,
                    PaidSales = g.Count(s => s.PaymentStatus == "Paid"),
                    PendingSales = g.Count(s => s.PaymentStatus == "Pending"),
                    CancelledSales = g.Count(s => s.PaymentStatus == "Cancelled")
                })
                .FirstOrDefaultAsync();

            return stats ?? new { TotalSales = 0, TotalRevenue = 0.0, AverageOrderValue = 0.0, PaidSales = 0, PendingSales = 0, CancelledSales = 0 };
        }

        /// <summary>
        /// Obține total revenue pentru o perioadă (doar plăți confirmate).
        /// </summary>
        public async Task<decimal> GetTotalRevenueAsync(DateTime fromDate, DateTime toDate)
        {
            var total = await _saleRepository
                .GetAll()
                .Where(s => s.IsActive && s.SaleDate >= fromDate && s.SaleDate < toDate.AddDays(1) && s.PaymentStatus == "Paid")
                .SumAsync(s => (double?)s.TotalAmount);

            return (decimal)(total ?? 0.0);
        }

        /// <summary>
        /// Obține vânzări dintr-un client.
        /// </summary>
        public async Task<List<Sale>> GetCustomerSalesAsync(int customerId)
        {
            return await _saleRepository
                .GetAll()
                .Where(s => s.CustomerId == customerId && s.IsActive)
                .OrderByDescending(s => s.SaleDate)
                .AsNoTracking()
                .ToListAsync();
        }

        /// <summary>
        /// Obține vânzări dintr-un utilizator (vânzări efectuate de).
        /// </summary>
        public async Task<List<Sale>> GetUserSalesAsync(int userId)
        {
            return await _saleRepository
                .GetAll()
                .Where(s => s.UserId == userId && s.IsActive)
                .OrderByDescending(s => s.SaleDate)
                .AsNoTracking()
                .ToListAsync();
        }

        /// <summary>
        /// Adaugă o nouă vânzare cu detalii și procesează scăderea stocului.
        /// OPERAȚIE COMPLEXĂ - folosește tranzacție de bază de date.
        /// </summary>
        public async Task<bool> AddSaleWithDetailsAsync(Sale sale, List<SaleDetails> details, int userId)
        {
            if (sale == null)
                throw new ArgumentNullException(nameof(sale));

            if (details == null || details.Count == 0)
                throw new ArgumentException("Sale must contain at least one product detail.");

            ValidateSale(sale);

            if (_saleDetailsRepository == null || _productRepository == null)
                throw new InvalidOperationException("SaleDetailsRepository and ProductRepository are required for this operation.");

            // Verifică stocul disponibil pentru toate produsele
            foreach (var detail in details)
            {
                var product = await _productRepository.GetByIdAsync(detail.ProductId);
                if (product == null)
                    throw new InvalidOperationException($"Product {detail.ProductId} not found.");

                if (product.CurrentStock < detail.Quantity)
                    throw new InvalidOperationException($"Insufficient stock for {product.ProductName}. Available: {product.CurrentStock}, Requested: {detail.Quantity}");
            }

            try
            {
                // Set default values
                sale.UserId = userId;
                if (sale.SaleDate == default)
                    sale.SaleDate = DateTime.Now;
                if (string.IsNullOrWhiteSpace(sale.PaymentStatus))
                    sale.PaymentStatus = "Pending";

                // Adaugă vânzarea
                _saleRepository.Add(sale);
                await _saleRepository.SaveAsync();

                // Adaugă detaliile și scade stocul
                foreach (var detail in details)
                {
                    detail.SaleId = sale.SaleId;
                    _saleDetailsRepository.Add(detail);

                    var product = await _productRepository.GetByIdAsync(detail.ProductId);
                    product.CurrentStock -= detail.Quantity;
                    _productRepository.Update(product);
                }

                await _saleDetailsRepository.SaveAsync();
                await _productRepository.SaveAsync();

                // Creează tranzacții pentru tracking
                if (_transactionRepository != null)
                {
                    foreach (var detail in details)
                    {
                        var transaction = new Transaction
                        {
                            ProductId = detail.ProductId,
                            EntityId = sale.CustomerId,
                            UserId = userId,
                            Quantity = detail.Quantity,
                            Type = "Stock Out",
                            Date = DateTime.Now
                        };

                        _transactionRepository.Add(transaction);
                    }

                    await _transactionRepository.SaveAsync();
                }

                return true;
            }
            catch (Exception ex)
            {
                throw new InvalidOperationException("Failed to process sale.", ex);
            }
        }

        /// <summary>
        /// Actualizează status de plată al unei vânzări.
        /// </summary>
        public async Task<bool> UpdatePaymentStatusAsync(int saleId, string newStatus)
        {
            var validStatuses = new[] { "Paid", "Pending", "Cancelled" };
            if (!validStatuses.Contains(newStatus))
                throw new ArgumentException($"Invalid payment status. Must be one of: {string.Join(", ", validStatuses)}");

            var sale = await _saleRepository.GetByIdAsync(saleId);
            if (sale == null)
                return false;

            sale.PaymentStatus = newStatus;

            try
            {
                _saleRepository.Update(sale);
                await _saleRepository.SaveAsync();
                return true;
            }
            catch (Exception ex)
            {
                throw new InvalidOperationException("Failed to update payment status.", ex);
            }
        }

        /// <summary>
        /// Deactivează o vânzare (soft delete).
        /// </summary>
        public async Task<bool> DeactivateSaleAsync(int saleId)
        {
            var sale = await _saleRepository.GetByIdAsync(saleId);

            if (sale == null)
                return false;

            sale.IsActive = false;

            try
            {
                _saleRepository.Update(sale);
                await _saleRepository.SaveAsync();
                return true;
            }
            catch (Exception ex)
            {
                throw new InvalidOperationException("Failed to deactivate sale.", ex);
            }
        }

        /// <summary>
        /// Activează o vânzare deactivată.
        /// </summary>
        public async Task<bool> ActivateSaleAsync(int saleId)
        {
            var sale = await _saleRepository.GetByIdAsync(saleId);

            if (sale == null)
                return false;

            sale.IsActive = true;

            try
            {
                _saleRepository.Update(sale);
                await _saleRepository.SaveAsync();
                return true;
            }
            catch (Exception ex)
            {
                throw new InvalidOperationException("Failed to activate sale.", ex);
            }
        }

        /// <summary>
        /// Obține vânzarea după ID.
        /// </summary>
        public async Task<Sale> GetByIdAsync(int saleId)
        {
            return await _saleRepository.GetByIdAsync(saleId);
        }

        /// <summary>
        /// Obține numărul de vânzări active.
        /// </summary>
        public async Task<int> GetActiveSaleCountAsync()
        {
            return await _saleRepository
                .GetAll()
                .Where(s => s.IsActive)
                .CountAsync();
        }

        /// <summary>
        /// Validează datele vânzării.
        /// </summary>
        private void ValidateSale(Sale sale)
        {
            if (sale.CustomerId <= 0)
                throw new ArgumentException("Valid Customer ID is required.");

            if (sale.TotalAmount <= 0)
                throw new ArgumentException("Sale amount must be greater than 0.");

            if (string.IsNullOrWhiteSpace(sale.PaymentMethod))
                throw new ArgumentException("Payment method is required.");

            var validPaymentMethods = new[] { "Cash", "Card", "Transfer" };
            if (!validPaymentMethods.Contains(sale.PaymentMethod))
                throw new ArgumentException($"Invalid payment method. Must be one of: {string.Join(", ", validPaymentMethods)}");

            if (!string.IsNullOrWhiteSpace(sale.PaymentStatus))
            {
                var validStatuses = new[] { "Paid", "Pending", "Cancelled" };
                if (!validStatuses.Contains(sale.PaymentStatus))
                    throw new ArgumentException($"Invalid payment status. Must be one of: {string.Join(", ", validStatuses)}");
            }
        }

        /// <summary>
        /// Aplică sortarea query-ului.
        /// </summary>
        private IQueryable<Sale> ApplySorting(IQueryable<Sale> query, string sortBy, string sortOrder)
        {
            if (string.IsNullOrWhiteSpace(sortBy))
                sortBy = "SaleDate";

            var isDescending = sortOrder?.ToLower() == "desc";

            return sortBy.ToLower() switch
            {
                "saledate" => isDescending
                    ? query.OrderByDescending(s => s.SaleDate)
                    : query.OrderBy(s => s.SaleDate),
                "saleid" => isDescending
                    ? query.OrderByDescending(s => s.SaleId)
                    : query.OrderBy(s => s.SaleId),
                "totalamount" => isDescending
                    ? query.OrderByDescending(s => s.TotalAmount)
                    : query.OrderBy(s => s.TotalAmount),
                "customerid" => isDescending
                    ? query.OrderByDescending(s => s.CustomerId)
                    : query.OrderBy(s => s.CustomerId),
                "paymentstatus" => isDescending
                    ? query.OrderByDescending(s => s.PaymentStatus)
                    : query.OrderBy(s => s.PaymentStatus),
                _ => query.OrderByDescending(s => s.SaleDate)
            };
        }
    }
}
