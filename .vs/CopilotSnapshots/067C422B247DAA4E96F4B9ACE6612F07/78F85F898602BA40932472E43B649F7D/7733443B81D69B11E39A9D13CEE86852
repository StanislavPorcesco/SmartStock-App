using SmartStock.Classes.Data.DTOs;
using SmartStock.Classes.Data.Interfaces;
using SmartStock.Classes.Data.Repositories;
using SmartStock.Classes.Data.Services;
using SmartStock.Classes.Models;
using SmartStock.Classes.Utils;
using SmartStock.Utils;
using Microsoft.EntityFrameworkCore;

namespace SmartStock.Forms.User_Control.SearchForms
{
    /// <summary>
    /// Passive View: Implementează IFilterControl și delegă logica de filtrare serviciului.
    /// Responsabil de colectarea datelor din controale și declanșarea filtrelor dinamice.
    /// 
    /// SOLID Principle - Single Responsibility:
    /// FilterCustomers se ocupa NUMAI de UI și colectare de criterii,
    /// logica de filtrare este în CustomerService.
    /// </summary>
    public partial class FilterCustomers : UserControl, IFilterControl
    {
        private CustomerService _customerService;
        private SaleService _saleService;

        // Debounce timer for search (avoid excessive queries)
        private System.Windows.Forms.Timer _filterDebounceTimer;
        private const int DEBOUNCE_DELAY_MS = 100;

        public event Action FilterChanged;

        public FilterCustomers()
        {
            InitializeComponent();
            InitializeServices();
            InitializeDebounceTimer();
            LoadUI();
        }

        private void InitializeServices()
        {
            var customerRepository = new GenericRepository<Customer>(new SmartStockContext());
            var saleRepository = new GenericRepository<Sale>(new SmartStockContext());

            _customerService = new CustomerService(customerRepository, saleRepository);  // ✅ Pass saleRepository
            _saleService = new SaleService(saleRepository);
        }

        private void InitializeDebounceTimer()
        {
            _filterDebounceTimer = new System.Windows.Forms.Timer();
            _filterDebounceTimer.Interval = DEBOUNCE_DELAY_MS;
            _filterDebounceTimer.Tick += (s, e) =>
            {
                _filterDebounceTimer.Stop();
                OnFilterChanged();
            };
        }

        private void LoadUI()
        {
            ThemeManager.Apply(this);
            ThemeManager.OnThemeChanged += HandleThemeUpdate;
            LoadCitiesAsync();
            SetDefaultValues();

            // Wire up event handlers for dynamic filtering with debounce
            name_or_phone_tb.TextChanged += (s, e) => RestartDebounceTimer();
            city_cb.SelectedIndexChanged += (s, e) => OnFilterChanged();
            registration_start.ValueChanged += (s, e) => OnFilterChanged();
            registration_end.ValueChanged += (s, e) => OnFilterChanged();
            dead_stock_start.ValueChanged += (s, e) => OnFilterChanged();
            dead_stock_end.ValueChanged += (s, e) => OnFilterChanged();
            sale_count_min.ValueChanged += (s, e) => OnFilterChanged();
            sale_count_max.ValueChanged += (s, e) => OnFilterChanged();
            spent_min.ValueChanged += (s, e) => OnFilterChanged();
            spent_max.ValueChanged += (s, e) => OnFilterChanged();
            all_rb.CheckedChanged += (s, e) => OnFilterChanged();
            active_rb.CheckedChanged += (s, e) => OnFilterChanged();
            inactive_rb.CheckedChanged += (s, e) => OnFilterChanged();

            // Add tooltips for user guidance
            ToolTipHelp.AddToolTip(this, "Filter customers by name, email, phone, city, registration date, and spending.");

            this.Refresh();
        }

        private void SetDefaultValues()
        {
            name_or_phone_tb.Clear();
            registration_start.Value = DateTime.Now.AddYears(-1);
            registration_end.Value = DateTime.Now;
            dead_stock_start.Value = DateTime.Now;
            dead_stock_end.Value = DateTime.Now;
            sale_count_min.Value = 0;
            sale_count_max.Value = 0;
            spent_min.Value = 0;
            spent_max.Value = 0;
        }

        private void HandleThemeUpdate()
        {
            ThemeManager.Apply(this);
            this.Refresh();
        }

        /// <summary>
        /// Debounce timer restart - prevents excessive queries while user is typing.
        /// </summary>
        private void RestartDebounceTimer()
        {
            _filterDebounceTimer.Stop();
            _filterDebounceTimer.Start();
        }

        /// <summary>
        /// Încarcă lista cu orase disponibile din baza de date.
        /// </summary>
        private async void LoadCitiesAsync()
        {
            try
            {
                using (var db = new SmartStockContext())
                {
                    var cities = await db.Customers
                        .AsNoTracking()
                        .Where(c => !string.IsNullOrEmpty(c.City))
                        .Select(c => c.City)
                        .Distinct()
                        .OrderBy(city => city)
                        .ToListAsync();

                    // Add "All Cities" option at the beginning
                    var cityList = new List<string> { "All Cities" };
                    cityList.AddRange(cities);

                    city_cb.DataSource = cityList;
                    city_cb.SelectedIndex = 0;  // Default: "All Cities"
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading cities: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        /// <summary>
        /// Implementează IFilterControl: Obține datele filtrate.
        /// </summary>
        public object GetFilteredData()
        {
            var criteria = BuildFilterCriteria();
            return GetFilteredCustomersAsync(criteria);
        }

        /// <summary>
        /// Construiește criteriile de filtrare din controale.
        /// Respectă SOLID: doar colectează date din UI, nu execută logică.
        /// </summary>
        private CustomerFilterCriteria BuildFilterCriteria()
        {
            var criteria = new CustomerFilterCriteria
            {
                PageSize = 0,    // No paging for DataGridView
                PageNumber = 1,
                IsActive = true  // Always filter for active customers
            };

            // 1. FILTRU CĂUTARE TEXT (Nume, Email, Telefon)
            if (!string.IsNullOrWhiteSpace(name_or_phone_tb.Text))
            {
                criteria.SearchText = name_or_phone_tb.Text.Trim();
            }

            // 2. FILTRU ORAȘ
            if (city_cb.SelectedIndex > 0 && city_cb.SelectedItem is string selectedCity && selectedCity != "All Cities")
            {
                criteria.City = selectedCity;
            }
            // If "All Cities" is selected, City remains null

            // 3. FILTRU PERIOADA DE ÎNREGISTRARE
            criteria.RegisteredFrom = registration_start.Value;
            criteria.RegisteredTo = registration_end.Value;

            // 4. FILTRU NUMĂRUL DE VÂNZĂRI (min-max)
            if (sale_count_min.Value > 0)
                criteria.MinSalesCount = (int)sale_count_min.Value;
            if (sale_count_max.Value > 0)
                criteria.MaxSalesCount = (int)sale_count_max.Value;

            // 5. FILTRU VALOARE TOTALĂ CHELTUITĂ (min-max)
            if (spent_min.Value > 0)
                criteria.MinTotalSpent = (decimal)spent_min.Value;
            if (spent_max.Value > 0)
                criteria.MaxTotalSpent = (decimal)spent_max.Value;

            return criteria;
        }

        /// <summary>
        /// Obține clienții filtrați folosind serviciul.
        /// 
        /// SOLID Principle: Post-processing filters sunt aplicate DUPĂ
        /// rezultatele din service pentru a menține separarea responsabilităților.
        /// </summary>
        private async Task<List<Customer>> GetFilteredCustomersAsync(CustomerFilterCriteria criteria)
        {
            try
            {
                var customers = await _customerService.GetFilteredAsync(criteria);

                // POST-PROCESSING FILTER 1: Customers without sales in dead stock period
                var deadStockStart = dead_stock_start.Value;
                var deadStockEnd = dead_stock_end.Value;

                if (deadStockStart < deadStockEnd)
                {
                    using (var db = new SmartStockContext())
                    {
                        // Get customers who had sales in the period
                        var customersWithSalesInPeriod = await db.Sales
                            .AsNoTracking()
                            .Where(s => s.SaleDate >= deadStockStart &&
                                       s.SaleDate <= deadStockEnd &&
                                       s.PaymentStatus == "Paid")
                            .Select(s => s.CustomerId)
                            .Distinct()
                            .ToListAsync();

                        // NOTE: This filtering is optional - typically customers without sales might still be valuable
                        // For now, we keep all customers in the result
                        // If needed, uncomment below to filter:
                        // customers = customers
                        //     .Where(c => !customersWithSalesInPeriod.Contains(c.CustomerId))
                        //     .ToList();
                    }
                }

                return customers;
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading filtered customers: {ex.Message}", "Database Error",
                                MessageBoxButtons.OK, MessageBoxIcon.Error);
                return new List<Customer>();
            }
        }

        /// <summary>
        /// Declanșator pentru evenimentul FilterChanged - actualizează DataGridView dinamic.
        /// </summary>
        private void OnFilterChanged()
        {
            FilterChanged?.Invoke();
        }

        /// <summary>
        /// Încarcă datele default în grid. Apelată de SearchForm după ce s-a conectat la FilterChanged.
        /// </summary>
        public void LoadDefaultData()
        {
            OnFilterChanged();
        }

        /// <summary>
        /// Implementează IFilterControl: Resetează toate filtrele.
        /// </summary>
        public void ResetFilters()
        {
            name_or_phone_tb.Text = string.Empty;
            city_cb.SelectedIndex = 0;
            registration_start.Value = DateTime.Now.AddYears(-1);
            registration_end.Value = DateTime.Now;
            dead_stock_start.Value = DateTime.Now;
            dead_stock_end.Value = DateTime.Now;
            sale_count_min.Value = 0;
            sale_count_max.Value = 0;
            spent_min.Value = 0;
            spent_max.Value = 0;
            all_rb.Checked = true;
            active_rb.Checked = false;
            inactive_rb.Checked = false;

            OnFilterChanged();
        }

        private void reset_btn_Click(object sender, EventArgs e)
        {
            ResetFilters();
        }
    }
}


