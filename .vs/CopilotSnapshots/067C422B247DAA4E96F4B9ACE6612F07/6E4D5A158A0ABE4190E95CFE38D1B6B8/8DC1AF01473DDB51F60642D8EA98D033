using System.ComponentModel.DataAnnotations;
using System.ComponentModel.DataAnnotations.Schema;

namespace SmartStock.Classes.Models
{
    /// <summary>
    /// Entitatea de domeniu ExternalFactor - curată de orice logică de bază de date.
    /// Conține factori externi (Economic, Social, Weather) care influențează vânzările.
    /// Logica de acces la date și calculele este delegată ExternalFactorService.
    /// </summary>
    public class ExternalFactor
    {
        [Key]
        public int FactorId { get; set; }

        [Required]
        [StringLength(50)]
        public string FactorType { get; set; } // Economic, Social, Weather, etc.

        [StringLength(250)]
        public string Description { get; set; }

        [StringLength(100)]
        public string Region { get; set; }

        /// <summary>
        /// Valoarea numerică a factorului (folosit pentru regresie și prediciții AI).
        /// SQLite compatible decimal storage.
        /// </summary>
        [Required]
        [Column(TypeName = "decimal(18, 4)")]
        public decimal ImpactValue { get; set; }

        /// <summary>
        /// Tipul valorii: "Absolute" (valoare fixă), "Percentage" (procent), "Multiplier" (multiplicator).
        /// </summary>
        [Required]
        [StringLength(20)]
        public string ValueType { get; set; }

        [Required]
        public DateTime Date { get; set; } = DateTime.Now;

        /// <summary>
        /// Indicator soft delete - factori inactivi nu sunt utilizați în predicții AI,
        /// dar datele lor istorice sunt păstrate pentru audit.
        /// </summary>
        [Required]
        public bool IsActive { get; set; } = true;
    }
}
