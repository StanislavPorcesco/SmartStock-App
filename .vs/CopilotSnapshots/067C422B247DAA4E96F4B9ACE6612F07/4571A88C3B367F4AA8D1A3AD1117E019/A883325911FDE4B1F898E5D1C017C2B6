using SmartStock.Classes.Data.DTOs;
using SmartStock.Classes.Data.Interfaces;
using SmartStock.Classes.Data.Repositories;
using SmartStock.Classes.Data.Services;
using SmartStock.Classes.Models;
using SmartStock.Classes.Utils;
using SmartStock.Utils;
using Microsoft.EntityFrameworkCore;

namespace SmartStock.Forms.User_Control.SearchForms
{
    /// <summary>
    /// Passive View: Implementează IFilterControl și delegă logica de filtrare serviciului.
    /// Responsabil de colectarea datelor din controale și declanșarea filtrelor dinamice.
    /// 
    /// SOLID Principle - Single Responsibility:
    /// FilterSales se ocupa NUMAI de UI și colectare de criterii,
    /// logica de filtrare este în SaleService.
    /// </summary>
    public partial class FilterSales : UserControl, IFilterControl
    {
        private SaleService _saleService;
        private CustomerService _customerService;
        private UserService _userService;

        // Debounce timer for search (avoid excessive queries)
        private System.Windows.Forms.Timer _filterDebounceTimer;
        private const int DEBOUNCE_DELAY_MS = 100;

        public event Action FilterChanged;

        public FilterSales()
        {
            InitializeComponent();
            InitializeServices();
            InitializeDebounceTimer();
            LoadUI();
            this.PerformLayout();
        }

        private void InitializeServices()
        {
            var saleRepository = new GenericRepository<Sale>(new SmartStockContext());
            var customerRepository = new GenericRepository<Customer>(new SmartStockContext());
            var userRepository = new GenericRepository<User>(new SmartStockContext());

            _saleService = new SaleService(saleRepository);
            _customerService = new CustomerService(customerRepository);
            _userService = new UserService(userRepository);
        }

        private void InitializeDebounceTimer()
        {
            _filterDebounceTimer = new System.Windows.Forms.Timer();
            _filterDebounceTimer.Interval = DEBOUNCE_DELAY_MS;
            _filterDebounceTimer.Tick += (s, e) =>
            {
                _filterDebounceTimer.Stop();
                OnFilterChanged();
            };
        }

        private void LoadUI()
        {
            ThemeManager.Apply(this);
            ThemeManager.OnThemeChanged += HandleThemeUpdate;
            LoadPaymentStatusesAsync();
            LoadPaymentMethodsAsync();
            SetDefaultValues();

            // Wire up event handlers for dynamic filtering with debounce
            name_or_supplier_tb.TextChanged += (s, e) => RestartDebounceTimer();
            customer_id_tb.TextChanged += (s, e) => RestartDebounceTimer();
            user_id_tb.TextChanged += (s, e) => RestartDebounceTimer();
            contains_prod_tb.TextChanged += (s, e) => RestartDebounceTimer();
            contains_cat_tb.TextChanged += (s, e) => RestartDebounceTimer();
            payment_status_cb.SelectedIndexChanged += (s, e) => OnFilterChanged();
            payment_method_cb.SelectedIndexChanged += (s, e) => OnFilterChanged();
            sale_date_start.ValueChanged += (s, e) => OnFilterChanged();
            sale_date_end.ValueChanged += (s, e) => OnFilterChanged();
            total_amount_min.ValueChanged += (s, e) => OnFilterChanged();
            total_amount_max.ValueChanged += (s, e) => OnFilterChanged();
            items_count_min.ValueChanged += (s, e) => OnFilterChanged();
            items_count_max.ValueChanged += (s, e) => OnFilterChanged();

            tableLayoutPanel1.Padding = new Padding(0,0,25,0);
            panel1.Padding = new Padding(0, 10, 0, 30);
            ToolTipHelp.AddToolTip(this, "Filter sales by date range, customer, payment method, or payment status");
            
            this.Refresh();
        }

        private void SetDefaultValues()
        {
            name_or_supplier_tb.Clear();
            customer_id_tb.Clear();
            user_id_tb.Clear();
            contains_prod_tb.Clear();
            contains_cat_tb.Clear();
            sale_date_start.Value = DateTime.Now.AddMonths(-1);
            sale_date_end.Value = DateTime.Now;
            total_amount_min.Value = 0;
            total_amount_max.Value = 0;
            items_count_min.Value = 0;
            items_count_max.Value = 0;
            payment_status_cb.SelectedIndex = 0;
            payment_method_cb.SelectedIndex = 0;

        }

        private void HandleThemeUpdate()
        {
            ThemeManager.Apply(this);
            this.Refresh();
        }

        /// <summary>
        /// Debounce timer restart - prevents excessive queries while user is typing.
        /// </summary>
        private void RestartDebounceTimer()
        {
            _filterDebounceTimer.Stop();
            _filterDebounceTimer.Start();
        }

        /// <summary>
        /// Încarcă staturile de plată disponibile.
        /// </summary>
        private async void LoadPaymentStatusesAsync()
        {
            try
            {
                var statuses = new List<string>
                {
                    "All Statuses",
                    "Paid",
                    "Pending",
                    "Cancelled"
                };

                payment_status_cb.DataSource = statuses;
                payment_status_cb.SelectedIndex = 0;
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading payment statuses: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        /// <summary>
        /// Încarcă metodele de plată disponibile.
        /// </summary>
        private async void LoadPaymentMethodsAsync()
        {
            try
            {
                var methods = new List<string>
                {
                    "All Methods",
                    "Cash",
                    "Card",
                    "Transfer"
                };

                payment_method_cb.DataSource = methods;
                payment_method_cb.SelectedIndex = 0;
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading payment methods: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        /// <summary>
        /// Implementează IFilterControl: Obține datele filtrate.
        /// </summary>
        public object GetFilteredData()
        {
            var criteria = BuildFilterCriteria();
            return GetFilteredSalesAsync(criteria);
        }

        /// <summary>
        /// Construiește criteriile de filtrare din controale.
        /// Respectă SOLID: doar colectează date din UI, nu execută logică.
        /// </summary>
        private SaleFilterCriteria BuildFilterCriteria()
        {
            var criteria = new SaleFilterCriteria
            {
                PageSize = 0,    // No paging for DataGridView
                PageNumber = 1,
                IsActive = true, // Filter for active sales
                SortBy = "SaleDate",
                SortOrder = "desc"
            };

            // 1. FILTRU CĂUTARE TEXT (Customer Name sau User Name)
            if (!string.IsNullOrWhiteSpace(name_or_supplier_tb.Text))
            {
                criteria.SearchText = name_or_supplier_tb.Text.Trim();
            }

            // 2. FILTRU CUSTOMER ID
            if (!string.IsNullOrWhiteSpace(customer_id_tb.Text) && int.TryParse(customer_id_tb.Text, out int customerId))
            {
                criteria.CustomerId = customerId;
            }

            // 3. FILTRU USER ID
            if (!string.IsNullOrWhiteSpace(user_id_tb.Text) && int.TryParse(user_id_tb.Text, out int userId))
            {
                criteria.UserId = userId;
            }

            // 4. FILTRU PAYMENT STATUS
            if (payment_status_cb.SelectedIndex > 0 && payment_status_cb.SelectedItem is string paymentStatus
                && paymentStatus != "All Statuses")
            {
                criteria.PaymentStatus = paymentStatus;
            }

            // 5. FILTRU PAYMENT METHOD
            if (payment_method_cb.SelectedIndex > 0 && payment_method_cb.SelectedItem is string paymentMethod
                && paymentMethod != "All Methods")
            {
                criteria.PaymentMethod = paymentMethod;
            }

            // 6. FILTRU DATĂ VÂNZARE (Range)
            criteria.SaleDateFrom = sale_date_start.Value;
            criteria.SaleDateTo = sale_date_end.Value;

            // 7. FILTRU SUMA TOTALĂ (Range)
            if (total_amount_min.Value > 0)
                criteria.TotalAmountMin = (decimal)total_amount_min.Value;
            if (total_amount_max.Value > 0)
                criteria.TotalAmountMax = (decimal)total_amount_max.Value;

            // 8. FILTRU PRODUS (Deep Filtering - vânzări care conțin acest produs)
            if (!string.IsNullOrWhiteSpace(contains_prod_tb.Text) && int.TryParse(contains_prod_tb.Text, out int productId))
            {
                criteria.ContainsProductId = productId;
            }

            // 9. FILTRU CATEGORIE (Deep Filtering - vânzări cu produse din această categorie)
            if (!string.IsNullOrWhiteSpace(contains_cat_tb.Text) && int.TryParse(contains_cat_tb.Text, out int categoryId))
            {
                criteria.ContainsCategoryId = categoryId;
            }

            // 10. FILTRU NUMĂRUL DE ITEMI (min-max)
            if (items_count_min.Value > 0)
                criteria.MinItemsCount = (int)items_count_min.Value;
            if (items_count_max.Value > 0)
                criteria.MaxItemsCount = (int)items_count_max.Value;

            return criteria;
        }

        /// <summary>
        /// Obține vânzările filtrate folosind serviciul.
        /// </summary>
        private async Task<List<Sale>> GetFilteredSalesAsync(SaleFilterCriteria criteria)
        {
            try
            {
                return await _saleService.GetFilteredAsync(criteria);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading filtered sales: {ex.Message}", "Database Error",
                                MessageBoxButtons.OK, MessageBoxIcon.Error);
                return new List<Sale>();
            }
        }

        /// <summary>
        /// Declanșator pentru evenimentul FilterChanged - actualizează DataGridView dinamic.
        /// </summary>
        private void OnFilterChanged()
        {
            FilterChanged?.Invoke();
        }

        /// <summary>
        /// Încarcă datele default în grid. Apelată de SearchForm după ce s-a conectat la FilterChanged.
        /// </summary>
        public void LoadDefaultData()
        {
            OnFilterChanged();
        }

        /// <summary>
        /// Implementează IFilterControl: Resetează toate filtrele.
        /// </summary>
        public void ResetFilters()
        {
            name_or_supplier_tb.Text = string.Empty;
            customer_id_tb.Text = string.Empty;
            user_id_tb.Text = string.Empty;
            payment_status_cb.SelectedIndex = 0;
            payment_method_cb.SelectedIndex = 0;
            sale_date_start.Value = DateTime.Now.AddMonths(-1);
            sale_date_end.Value = DateTime.Now;
            total_amount_min.Value = 0;
            total_amount_max.Value = 0;
            contains_prod_tb.Text = string.Empty;
            contains_cat_tb.Text = string.Empty;
            items_count_min.Value = 0;
            items_count_max.Value = 0;

            OnFilterChanged();
        }
    }

}

