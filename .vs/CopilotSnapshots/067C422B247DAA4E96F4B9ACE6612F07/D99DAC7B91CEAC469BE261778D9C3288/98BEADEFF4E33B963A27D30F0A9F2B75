using Moq;
using SmartStock.Classes.Data.DTOs;
using SmartStock.Classes.Data.Interfaces;
using SmartStock.Classes.Data.Services;
using SmartStock.Classes.Models;

namespace SmartStock.Tests.Services
{
    /// <summary>
    /// Unit tests pentru ProductService - demonstrează testabilitate N-Tier
    /// </summary>
    [TestClass]
    public class ProductServiceTests
    {
        private Mock<IRepository<Product>> _mockRepository;
        private ProductService _productService;

        [TestInitialize]
        public void Setup()
        {
            _mockRepository = new Mock<IRepository<Product>>();
            _productService = new ProductService(_mockRepository.Object);
        }

        [TestMethod]
        public void Constructor_WithNullRepository_ThrowsArgumentNullException()
        {
            // Arrange & Act & Assert
            Assert.ThrowsException<ArgumentNullException>(() =>
                new ProductService(null)
            );
        }

        [TestMethod]
        public async Task AddProductAsync_WithValidProduct_ReturnsTrue()
        {
            // Arrange
            var product = new Product
            {
                ProductName = "Test Product",
                CategoryId = 1,
                SupplierId = 1,
                UnitPrice = 10.50m,
                CurrentStock = 100,
                SafetyStock = 20,
                UnitOfMeasure = "pcs",
                IsActive = true
            };

            _mockRepository.Setup(r => r.SaveAsync()).ReturnsAsync(1);

            // Act
            var result = await _productService.AddProductAsync(product);

            // Assert
            Assert.IsTrue(result);
            _mockRepository.Verify(r => r.Add(product), Times.Once);
            _mockRepository.Verify(r => r.SaveAsync(), Times.Once);
        }

        [TestMethod]
        public async Task AddProductAsync_WithNullProduct_ThrowsArgumentNullException()
        {
            // Act & Assert
            await Assert.ThrowsExceptionAsync<ArgumentNullException>(() =>
                _productService.AddProductAsync(null)
            );
        }

        [TestMethod]
        public async Task AddProductAsync_WithInvalidData_ThrowsArgumentException()
        {
            // Arrange
            var invalidProduct = new Product
            {
                ProductName = "", // Validare va eșua
                CategoryId = 1,
                SupplierId = 1,
                UnitPrice = 10,
                CurrentStock = 100,
                SafetyStock = 20,
                UnitOfMeasure = "pcs",
                IsActive = true
            };

            // Act & Assert
            await Assert.ThrowsExceptionAsync<ArgumentException>(() =>
                _productService.AddProductAsync(invalidProduct)
            );
        }

        [TestMethod]
        public async Task UpdateStockAsync_WithValidProductId_ReturnsTrue()
        {
            // Arrange
            int productId = 1;
            int newStock = 50;
            var existingProduct = new Product { ProductId = productId, CurrentStock = 100 };

            _mockRepository.Setup(r => r.GetByIdAsync(productId))
                .ReturnsAsync(existingProduct);
            _mockRepository.Setup(r => r.SaveAsync()).ReturnsAsync(1);

            // Act
            var result = await _productService.UpdateStockAsync(productId, newStock);

            // Assert
            Assert.IsTrue(result);
            Assert.AreEqual(50, existingProduct.CurrentStock);
            _mockRepository.Verify(r => r.Update(existingProduct), Times.Once);
        }

        [TestMethod]
        public async Task UpdateStockAsync_WithInvalidProductId_ReturnsFalse()
        {
            // Arrange
            _mockRepository.Setup(r => r.GetByIdAsync(It.IsAny<object>()))
                .ReturnsAsync((Product)null);

            // Act
            var result = await _productService.UpdateStockAsync(999, 100);

            // Assert
            Assert.IsFalse(result);
        }

        [TestMethod]
        public async Task DeactivateProductAsync_WithValidProductId_ReturnsTrue()
        {
            // Arrange
            int productId = 1;
            var product = new Product { ProductId = productId, IsActive = true };

            _mockRepository.Setup(r => r.GetByIdAsync(productId))
                .ReturnsAsync(product);
            _mockRepository.Setup(r => r.SaveAsync()).ReturnsAsync(1);

            // Act
            var result = await _productService.DeactivateProductAsync(productId);

            // Assert
            Assert.IsTrue(result);
            Assert.IsFalse(product.IsActive);
            _mockRepository.Verify(r => r.Update(product), Times.Once);
        }

        [TestMethod]
        public async Task GetFilteredAsync_WithNullCriteria_ThrowsArgumentNullException()
        {
            // Act & Assert
            await Assert.ThrowsExceptionAsync<ArgumentNullException>(() =>
                _productService.GetFilteredAsync(null)
            );
        }

        [TestMethod]
        public async Task GetFilteredAsync_WithValidCriteria_ReturnsFilteredProducts()
        {
            // Arrange
            var criteria = new ProductFilterCriteria
            {
                CategoryId = 1,
                IsActive = true,
                PageSize = 10,
                PageNumber = 1
            };

            var mockProducts = new List<Product>
            {
                new Product { ProductId = 1, ProductName = "Product 1", CategoryId = 1, IsActive = true },
                new Product { ProductId = 2, ProductName = "Product 2", CategoryId = 1, IsActive = true }
            };

            var mockQueryable = mockProducts.AsQueryable();

            _mockRepository.Setup(r => r.GetAll())
                .Returns(mockQueryable);

            // Act
            var result = await _productService.GetFilteredAsync(criteria);

            // Assert
            Assert.IsNotNull(result);
            Assert.IsInstanceOfType(result, typeof(List<Product>));
        }

        [TestMethod]
        public async Task GetLowStockProductsAsync_ReturnsOnlyUnderSafetyLimit()
        {
            // Arrange
            var lowStockProducts = new List<Product>
            {
                new Product
                {
                    ProductId = 1,
                    ProductName = "Low Stock",
                    CurrentStock = 5,
                    SafetyStock = 20,
                    IsActive = true
                }
            };

            var mockQueryable = lowStockProducts.AsQueryable();

            _mockRepository.Setup(r => r.GetAll())
                .Returns(mockQueryable);

            // Act
            var result = await _productService.GetLowStockProductsAsync();

            // Assert
            Assert.IsNotNull(result);
            Assert.IsTrue(result.All(p => p.CurrentStock < p.SafetyStock));
        }

        [TestMethod]
        public async Task GetTotalInventoryValueAsync_CalculatesCorrectly()
        {
            // Arrange
            var products = new List<Product>
            {
                new Product { ProductId = 1, UnitPrice = 10.00m, CurrentStock = 100, IsActive = true },
                new Product { ProductId = 2, UnitPrice = 20.00m, CurrentStock = 50, IsActive = true }
                // Expected: (10 * 100) + (20 * 50) = 1000 + 1000 = 2000
            };

            var mockQueryable = products.AsQueryable();

            _mockRepository.Setup(r => r.GetAll())
                .Returns(mockQueryable);

            // Act
            var result = await _productService.GetTotalInventoryValueAsync();

            // Assert
            Assert.AreEqual(2000m, result);
        }

        [TestMethod]
        [DataRow("ProductName", "asc")]
        [DataRow("UnitPrice", "desc")]
        [DataRow("CurrentStock", "asc")]
        public async Task ApplySorting_WithVariousOptions_ReturnsSortedResults(
            string sortBy, string sortOrder)
        {
            // Arrange
            var criteria = new ProductFilterCriteria
            {
                SortBy = sortBy,
                SortOrder = sortOrder,
                PageSize = 10,
                PageNumber = 1
            };

            var products = new List<Product>
            {
                new Product { ProductId = 1, ProductName = "Zebra", UnitPrice = 50 },
                new Product { ProductId = 2, ProductName = "Apple", UnitPrice = 10 }
            };

            var mockQueryable = products.AsQueryable();

            _mockRepository.Setup(r => r.GetAll())
                .Returns(mockQueryable);

            // Act
            var result = await _productService.GetFilteredAsync(criteria);

            // Assert
            Assert.IsNotNull(result);
        }

        [TestMethod]
        public async Task ValidateProduct_WithInvalidData_ThrowsArgumentException()
        {
            // Arrange
            var invalidProducts = new List<Product>
            {
                new Product { ProductName = "", CategoryId = 1, SupplierId = 1, UnitPrice = 10 },
                new Product { ProductName = "Test", CategoryId = 0, SupplierId = 1, UnitPrice = 10 },
                new Product { ProductName = "Test", CategoryId = 1, SupplierId = 1, UnitPrice = -5 }
            };

            // Act & Assert
            foreach (var product in invalidProducts)
            {
                await Assert.ThrowsExceptionAsync<ArgumentException>(() =>
                    _productService.AddProductAsync(product)
                );
            }
        }
    }
}
