using System.ComponentModel.DataAnnotations;
using System.ComponentModel.DataAnnotations.Schema;

namespace SmartStock.Classes.Models
{
    /// <summary>
    /// Entitatea de domeniu Transaction - curată de orice logică de bază de date.
    /// Logica de acces la date și management stoc este delegată TransactionService.
    /// </summary>
    public class Transaction
    {
        [Key]
        public int TransactionId { get; set; }

        [Required]
        public int ProductId { get; set; }

        /// <summary>
        /// EntityId poate fi SupplierId (pentru Stock In) sau CustomerId (pentru Stock Out).
        /// </summary>
        public int? EntityId { get; set; }

        [Required]
        public int UserId { get; set; }

        [Required]
        public int Quantity { get; set; }

        [Required]
        [StringLength(20)]
        public string Type { get; set; } // "Stock In", "Stock Out", "Adjustment"

        [Required]
        public DateTime Date { get; set; } = DateTime.Now;

        /// <summary>
        /// Proprietate de navigare către Produs.
        /// Lazy loading - se încarcă cu Include() în serviciu.
        /// </summary>
        [ForeignKey("ProductId")]
        public virtual Product Product { get; set; }

        /// <summary>
        /// Proprietate de navigare către Utilizator.
        /// Lazy loading - se încarcă cu Include() în serviciu.
        /// </summary>
        [ForeignKey("UserId")]
        public virtual User User { get; set; }
    }
}

