using System.ComponentModel.DataAnnotations;

namespace SmartStock.Classes.Models
{
    /// <summary>
    /// Entitatea de domeniu Customer - curată de orice logică de bază de date.
    /// Logica de acces la date este delegată CustomerService.
    /// </summary>
    public class Customer
    {
        [Key]
        public int CustomerId { get; set; }

        [Required]
        [StringLength(150)]
        public string FullName { get; set; }

        [StringLength(100)]
        public string City { get; set; }

        [EmailAddress]
        [StringLength(100)]
        public string Email { get; set; }

        [Phone]
        [StringLength(20)]
        public string Phone { get; set; }

        [Required]
        public DateTime RegistrationDate { get; set; } = DateTime.Now;

        [Required]
        public bool IsActive { get; set; }

        /// <summary>
        /// Colecție virtuală de comenzi din acest client.
        /// Lazy loading - se încarcă cu Include() în serviciu.
        /// </summary>
        public virtual ICollection<Sale> Sales { get; set; } = new List<Sale>();
    }
}

