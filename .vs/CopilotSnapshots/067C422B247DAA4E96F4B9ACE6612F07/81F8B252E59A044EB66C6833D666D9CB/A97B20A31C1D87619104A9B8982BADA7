using SmartStock.Classes.Data.DTOs;
using SmartStock.Classes.Data.Interfaces;
using SmartStock.Classes.Data.Repositories;
using SmartStock.Classes.Data.Services;
using SmartStock.Classes.Models;
using SmartStock.Classes.Utils;
using SmartStock.Utils;

namespace SmartStock.Forms.User_Control.SearchForms
{
    /// <summary>
    /// Passive View: Implementează IFilterControl și delegă logica de filtrare serviciului.
    /// Responsabil doar de colectarea datelor din controale și afișare.
    /// </summary>
    public partial class FilterUsers : UserControl, IFilterControl
    {
        private UserService _userService;

        public event Action FilterChanged;

        public FilterUsers()
        {
            InitializeComponent();
            InitializeService();
            LoadUI();
        }

        private void InitializeService()
        {
            var repository = new GenericRepository<User>(new SmartStockContext());
            _userService = new UserService(repository);
        }

        private void LoadUI()
        {
            ThemeManager.Apply(this);
            ThemeManager.OnThemeChanged += HandleThemeUpdate;
            this.Refresh();

            ToolTipHelp.AddToolTip(this, "Filter users by role, status, or search by username/name/email");
        }

        private void HandleThemeUpdate()
        {
            ThemeManager.Apply(this);
            this.Refresh();
        }

        /// <summary>
        /// Implementează IFilterControl: Obține datele filtrate.
        /// </summary>
        public object GetFilteredData()
        {
            var criteria = BuildFilterCriteria();
            return GetFilteredUsersAsync(criteria);
        }

        /// <summary>
        /// Construiește criteriile de filtrare din controale.
        /// </summary>
        private UserFilterCriteria BuildFilterCriteria()
        {
            var criteria = new UserFilterCriteria();

            // Add filtering logic here based on UI controls if needed
            // For example: criteria.Role = selectedRole;

            return criteria;
        }

        /// <summary>
        /// Obține utilizatorii filtrați folosind serviciul.
        /// </summary>
        private async Task<List<User>> GetFilteredUsersAsync(UserFilterCriteria criteria)
        {
            try
            {
                return await _userService.GetFilteredAsync(criteria);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading filtered users: {ex.Message}", "Database Error",
                                MessageBoxButtons.OK, MessageBoxIcon.Error);
                return new List<User>();
            }
        }

        /// <summary>
        /// Implementează IFilterControl: Resetează filtrele.
        /// </summary>
        public void ResetFilters()
        {
            FilterChanged?.Invoke();
        }

        /// <summary>
        /// Declanșator pentru evenimentul FilterChanged.
        /// </summary>
        protected void OnFilterChanged()
        {
            FilterChanged?.Invoke();
        }
    }
}
