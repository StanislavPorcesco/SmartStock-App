# SmartStock secrets - API keys and Gmail app passwords.
# Copy this file to ".env" and fill in the values, OR let the app create one for you:
# on first run an empty .env is generated in the data folder
# (%ProgramData%\SmartStock\.env, or "SmartStock (Dev)" for DEBUG builds).
# This file is the ONLY place secrets are read from. The real .env is git-ignored.

# DeepSeek (default AI provider) - https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic / Claude - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Alpha Vantage (commodity prices) - https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# PredictHQ (events) - https://control.predicthq.com/
PREDICTHQ_API_KEY=

# Gmail app password for smartstock.auth@gmail.com (login verification codes)
AUTH_EMAIL_PASSWORD=

# Gmail app password for smartstock.reports@gmail.com (weekly reports)
REPORTS_EMAIL_PASSWORD=
